{
  "name": "sticky",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:production-smoke": "node scripts/production-smoke.mjs",
    "visual:mockups": "node scripts/verify-mockup-sliced-visuals.mjs",
    "materials:premium": "python scripts/generate-premium-materials.py",
    "security:check": "node scripts/security-check.mjs",
    "schema:check": "node scripts/schema-check.mjs",
    "audit:moderate": "npm audit --audit-level=moderate",
    "launch:check": "node scripts/launch-readiness.mjs",
    "verify": "npm run typecheck && npm run lint && npm run security:check && npm run schema:check && npm run build && npm run audit:moderate && npm run test:e2e"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/sortable": "10.0.0",
    "@dnd-kit/utilities": "3.2.2",
    "@fontsource/kalam": "^5.2.8",
    "@fontsource/nunito": "^5.2.7",
    "@supabase/ssr": "0.12.0",
    "@supabase/supabase-js": "2.108.1",
    "date-fns": "4.4.0",
    "framer-motion": "12.40.0",
    "lucide-react": "1.18.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
